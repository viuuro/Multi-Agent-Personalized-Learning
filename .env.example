# MiMo-v2.5 API 密钥（必填）
# 申请地址：https://api.xiaomimimo.com
MIMO_API_KEY=your_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
# 对话智能体与 mimo-v2.5-tts 语音模型共同使用以上 API Key 和 Base URL。

# MySQL 数据库配置（可选）。后端优先读取 DB_*，也兼容 MYSQL_*。
# 本地开发只需设置其中一组；不要把真实密码提交到 Git。
DB_URL=jdbc:mysql://localhost:3306/edu_agent?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USER=root
DB_PASSWORD=your_password_here
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# Python AI 服务地址（可选，有默认值）
PYTHON_AI_URL=http://localhost:8000
PYTHON_AI_ALLOWED_HOSTS=127.0.0.1,localhost

# Web 安全配置：生产环境仅填写实际前端 HTTPS 来源，不能使用 *
APP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_COOKIE_SECURE=false

# 独立图片生成接口（可选；未配置时图片生成功能返回 503，不复用 MiMo Key）
IMAGE_GENERATION_API_BASE=https://ark.cn-beijing.volces.com/api/v3
IMAGE_GENERATION_API_KEY=your_ark_api_key
# Seedream 5.0 Lite 图片模型
IMAGE_GENERATION_MODEL=doubao-seedream-5-0-lite-260128
IMAGE_GENERATION_SIZE=2K
